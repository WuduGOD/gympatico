          )}
        </section>
      </div>

      {/* PRAWA STRONA: RANKING STREAKÓW GANGU */}
      <section className="lg:col-span-2 bg-gymCard p-4 md:p-6 rounded-xl shadow-lg border border-zinc-800/40">
